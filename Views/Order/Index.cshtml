@model PocMvcApp.Models.OrderViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Order Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Order Management</h2>
        <a asp-action="Create" class="btn btn-primary">Create New Order</a>
    </div>

    @if (Model.Orders.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Order Date</th>
                        <th>Status</th>
                        <th>Total Amount</th>
                        <th>Items</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>
                                @if (order.Customer != null)
                                {
                                    <div>@order.Customer.Name</div>
                                    <small class="text-muted">@order.Customer.Email</small>
                                }
                                else
                                {
                                    <span class="text-muted">Customer Not Found</span>
                                }
                            </td>
                            <td>@order.OrderDate.ToString("MM/dd/yyyy HH:mm")</td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm dropdown-toggle @GetStatusBadgeClass(order.Status)" type="button" data-bs-toggle="dropdown">
                                        @order.Status
                                    </button>
                                    <ul class="dropdown-menu">
                                        @foreach (var status in Enum.GetValues<PocMvcApp.Models.OrderStatus>())
                                        {
                                            <li>
                                                <form asp-action="UpdateStatus" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@order.Id" />
                                                    <input type="hidden" name="status" value="@status" />
                                                    <button type="submit" class="dropdown-item @(order.Status == status ? "active" : "")">
                                                        @status
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                            <td><strong>$@order.TotalAmount.ToString("F2")</strong></td>
                            <td>
                                <span class="badge bg-secondary">@order.OrderItems.Count item(s)</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info">Details</a>
                                    <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-warning">Edit</a>
                                    <form asp-action="Delete" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this order?');">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <h4>No Orders Found</h4>
            <p>There are no orders in the system. <a asp-action="Create" class="btn btn-primary btn-sm">Create your first order</a></p>
        </div>
    }

    <div class="mt-4">
        <a asp-action="Customers" class="btn btn-secondary">Manage Customers</a>
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary">Manage Products</a>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(PocMvcApp.Models.OrderStatus status)
    {
        return status switch
        {
            PocMvcApp.Models.OrderStatus.Pending => "btn-warning",
            PocMvcApp.Models.OrderStatus.Processing => "btn-primary",
            PocMvcApp.Models.OrderStatus.Shipped => "btn-info",
            PocMvcApp.Models.OrderStatus.Delivered => "btn-success",
            PocMvcApp.Models.OrderStatus.Cancelled => "btn-danger",
            _ => "btn-secondary"
        };
    }
}