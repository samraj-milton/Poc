@model PocMvcApp.Models.OrderViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Order";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Edit Order #@Model.Order.Id</h2>
        <div>
            <a asp-action="Details" asp-route-id="@Model.Order.Id" class="btn btn-info">View Details</a>
            <a asp-action="Index" class="btn btn-secondary">Back to Orders</a>
        </div>
    </div>

    <form asp-action="Edit" method="post" id="editOrderForm">
        <input type="hidden" asp-for="Order.Id" />
        <input type="hidden" asp-for="Order.OrderDate" />

        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5>Order Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Order.CustomerId" class="form-label">Customer *</label>
                            <select asp-for="Order.CustomerId" class="form-select" required>
                                <option value="">Select a customer...</option>
                                @foreach (var customer in Model.Customers)
                                {
                                    <option value="@customer.Id" selected="@(customer.Id == Model.Order.CustomerId)">@customer.Name (@customer.Email)</option>
                                }
                            </select>
                            <span asp-validation-for="Order.CustomerId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Order.Status" class="form-label">Status</label>
                            <select asp-for="Order.Status" class="form-select">
                                @foreach (var status in Enum.GetValues<PocMvcApp.Models.OrderStatus>())
                                {
                                    <option value="@status" selected="@(status == Model.Order.Status)">@status</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Order.Notes" class="form-label">Notes</label>
                            <textarea asp-for="Order.Notes" class="form-control" rows="3" placeholder="Optional order notes...">@Model.Order.Notes</textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Order Date</label>
                            <input type="text" class="form-control" value="@Model.Order.OrderDate.ToString("MMMM dd, yyyy 'at' HH:mm")" readonly />
                            <small class="text-muted">Order date cannot be modified</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5>Order Items</h5>
                        <button type="button" class="btn btn-sm btn-primary" onclick="addOrderItem()">Add Item</button>
                    </div>
                    <div class="card-body">
                        <div id="orderItems">
                            @for (int i = 0; i < Model.Order.OrderItems.Count; i++)
                            {
                                <div class="order-item border rounded p-3 mb-3" data-index="@i">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h6>Item @(i + 1)</h6>
                                        <button type="button" class="btn btn-sm btn-danger" onclick="removeOrderItem(@i)">Remove</button>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">Product *</label>
                                            <select name="Order.OrderItems[@i].ProductId" class="form-select product-select" onchange="updatePrice(@i)" required>
                                                <option value="">Select a product...</option>
                                                @foreach (var product in Model.Products)
                                                {
                                                    <option value="@product.Id" data-price="@product.Price" selected="@(product.Id == Model.Order.OrderItems[i].ProductId)">@product.Name - $@product.Price.ToString("F2")</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Quantity *</label>
                                            <input type="number" name="Order.OrderItems[@i].Quantity" class="form-control quantity-input" min="1" value="@Model.Order.OrderItems[i].Quantity" onchange="updateItemTotal(@i)" required />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Unit Price</label>
                                            <input type="number" name="Order.OrderItems[@i].UnitPrice" class="form-control unit-price" step="0.01" value="@Model.Order.OrderItems[i].UnitPrice" readonly />
                                        </div>
                                    </div>
                                    <div class="mt-2">
                                        <small class="text-muted">Item Total: $<span class="item-total">@Model.Order.OrderItems[i].TotalPrice.ToString("F2")</span></small>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <strong>Total: $<span id="totalAmount">@Model.Order.TotalAmount.ToString("F2")</span></strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success">Update Order</button>
            <a asp-action="Details" asp-route-id="@Model.Order.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let itemIndex = @Model.Order.OrderItems.Count;
        const products = @Html.Raw(Json.Serialize(Model.Products.Select(p => new { p.Id, p.Name, p.Price })));

        function addOrderItem() {
            const container = document.getElementById('orderItems');
            const itemHtml = `
                <div class="order-item border rounded p-3 mb-3" data-index="${itemIndex}">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6>Item ${itemIndex + 1}</h6>
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeOrderItem(${itemIndex})">Remove</button>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label">Product *</label>
                            <select name="Order.OrderItems[${itemIndex}].ProductId" class="form-select product-select" onchange="updatePrice(${itemIndex})" required>
                                <option value="">Select a product...</option>
                                ${products.map(p => `<option value="${p.Id}" data-price="${p.Price}">${p.Name} - $${(p.Price || 0).toFixed(2)}</option>`).join('')}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Quantity *</label>
                            <input type="number" name="Order.OrderItems[${itemIndex}].Quantity" class="form-control quantity-input" min="1" value="1" onchange="updateItemTotal(${itemIndex})" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Unit Price</label>
                            <input type="number" name="Order.OrderItems[${itemIndex}].UnitPrice" class="form-control unit-price" step="0.01" readonly />
                        </div>
                    </div>
                    <div class="mt-2">
                        <small class="text-muted">Item Total: $<span class="item-total">0.00</span></small>
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', itemHtml);
            itemIndex++;
        }

        function removeOrderItem(index) {
            const item = document.querySelector(`[data-index="${index}"]`);
            if (item) {
                item.remove();
                updateTotalAmount();
                reindexItems();
            }
        }

        function updatePrice(index) {
            const productSelect = document.querySelector(`[data-index="${index}"] .product-select`);
            const unitPriceInput = document.querySelector(`[data-index="${index}"] .unit-price`);
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            
            if (selectedOption && selectedOption.value) {
                const price = parseFloat(selectedOption.getAttribute('data-price'));
                unitPriceInput.value = price.toFixed(2);
                updateItemTotal(index);
            } else {
                unitPriceInput.value = '';
                updateItemTotal(index);
            }
        }

        function updateItemTotal(index) {
            const item = document.querySelector(`[data-index="${index}"]`);
            const quantity = parseInt(item.querySelector('.quantity-input').value) || 0;
            const unitPrice = parseFloat(item.querySelector('.unit-price').value) || 0;
            const total = quantity * unitPrice;
            
            item.querySelector('.item-total').textContent = total.toFixed(2);
            updateTotalAmount();
        }

        function updateTotalAmount() {
            let total = 0;
            document.querySelectorAll('.item-total').forEach(span => {
                total += parseFloat(span.textContent) || 0;
            });
            document.getElementById('totalAmount').textContent = total.toFixed(2);
        }

        function reindexItems() {
            let newIndex = 0;
            document.querySelectorAll('.order-item').forEach(item => {
                item.setAttribute('data-index', newIndex);
                item.querySelector('h6').textContent = `Item ${newIndex + 1}`;
                
                // Update form field names
                const inputs = item.querySelectorAll('input, select');
                inputs.forEach(input => {
                    const name = input.getAttribute('name');
                    if (name && name.includes('OrderItems[')) {
                        const newName = name.replace(/OrderItems\[\d+\]/, `OrderItems[${newIndex}]`);
                        input.setAttribute('name', newName);
                    }
                });
                
                // Update onchange handlers
                const productSelect = item.querySelector('.product-select');
                const quantityInput = item.querySelector('.quantity-input');
                const removeButton = item.querySelector('.btn-danger');
                
                if (productSelect) productSelect.setAttribute('onchange', `updatePrice(${newIndex})`);
                if (quantityInput) quantityInput.setAttribute('onchange', `updateItemTotal(${newIndex})`);
                if (removeButton) removeButton.setAttribute('onclick', `removeOrderItem(${newIndex})`);
                
                newIndex++;
            });
            itemIndex = newIndex;
        }

        // Calculate initial total
        document.addEventListener('DOMContentLoaded', function() {
            updateTotalAmount();
        });
    </script>
}