@model PocMvcApp.Models.ProductViewModel
@{
    Layout = "_Layout";
}
<div class="container mt-4">
    <h2 class="mb-3">Product List</h2>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Description</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <tr id="row-@item.Id">
                    <td>
                        <span id="name-@item.Id">@item.Name</span>
                        <input id="edit-name-@item.Id" name="Name" value="@item.Name" class="form-control form-control-sm" style="width:100px;display:none" />
                    </td>
                    <td>
                        <span id="price-@item.Id">@item.Price</span>
                        <input id="edit-price-@item.Id" name="Price" value="@item.Price" type="number" step="0.01" class="form-control form-control-sm" style="width:80px;display:none" />
                    </td>
                    <td>
                        <span id="desc-@item.Id">@item.Description</span>
                        <input id="edit-desc-@item.Id" name="Description" value="@item.Description" class="form-control form-control-sm" style="width:120px;display:none" />
                    </td>
                    <td>
                        <span id="cat-@item.Id">@item.Category</span>
                        <input id="edit-cat-@item.Id" name="Category" value="@item.Category" class="form-control form-control-sm" style="width:100px;display:none" />
                    </td>
                    <td>
                        <span id="stock-@item.Id">@item.Stock</span>
                        <input id="edit-stock-@item.Id" name="Stock" value="@item.Stock" type="number" class="form-control form-control-sm" style="width:60px;display:none" />
                    </td>
                    <td>
                        <div class="d-flex flex-row flex-wrap gap-1">
                            <button type="button" class="btn btn-sm btn-primary" onclick="enableEdit(@item.Id)">Edit</button>
                            <form id="edit-form-@item.Id" asp-action="Edit" method="post" style="display:none;">
                                <input type="hidden" name="Id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Save</button>
                                <button type="button" class="btn btn-sm btn-secondary" onclick="cancelEdit(@item.Id)">Cancel</button>
                            </form>
                            <form asp-action="Delete" method="post" style="display:inline;">
                                <input type="hidden" name="Id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this product?');">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h2 class="mt-5 mb-3">Add Product</h2>
    <form asp-action="Add" method="post" class="row g-3">
        <div class="col-md-2">
            <label class="form-label">Name</label>
            <input asp-for="Product.Name" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Price</label>
            <input asp-for="Product.Price" type="number" step="0.01" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Description</label>
            <input asp-for="Product.Description" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Category</label>
            <input asp-for="Product.Category" class="form-control" />
        </div>
        <div class="col-md-1">
            <label class="form-label">Stock</label>
            <input asp-for="Product.Stock" type="number" class="form-control" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-success w-100">Add</button>
        </div>
    </form>
</div>

<div id="editProductModal" style="display:none;">
    <h2>Edit Product</h2>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Product.Id" />
        <div>
            <label>Name</label>
            <input asp-for="Product.Name" />
        </div>
        <div>
            <label>Price</label>
            <input asp-for="Product.Price" type="number" step="0.01" />
        </div>
        <div>
            <label>Description</label>
            <input asp-for="Product.Description" />
        </div>
        <div>
            <label>Category</label>
            <input asp-for="Product.Category" />
        </div>
        <div>
            <label>Stock</label>
            <input asp-for="Product.Stock" type="number" />
        </div>
        <button type="submit">Save</button>
        <button type="button" onclick="hideEdit()">Cancel</button>
    </form>
</div>

<script>
function enableEdit(id) {
    document.getElementById('name-' + id).style.display = 'none';
    document.getElementById('price-' + id).style.display = 'none';
    document.getElementById('desc-' + id).style.display = 'none';
    document.getElementById('cat-' + id).style.display = 'none';
    document.getElementById('stock-' + id).style.display = 'none';
    document.getElementById('edit-name-' + id).style.display = '';
    document.getElementById('edit-price-' + id).style.display = '';
    document.getElementById('edit-desc-' + id).style.display = '';
    document.getElementById('edit-cat-' + id).style.display = '';
    document.getElementById('edit-stock-' + id).style.display = '';
    document.getElementById('edit-form-' + id).style.display = '';
}
function cancelEdit(id) {
    document.getElementById('name-' + id).style.display = '';
    document.getElementById('price-' + id).style.display = '';
    document.getElementById('desc-' + id).style.display = '';
    document.getElementById('cat-' + id).style.display = '';
    document.getElementById('stock-' + id).style.display = '';
    document.getElementById('edit-name-' + id).style.display = 'none';
    document.getElementById('edit-price-' + id).style.display = 'none';
    document.getElementById('edit-desc-' + id).style.display = 'none';
    document.getElementById('edit-cat-' + id).style.display = 'none';
    document.getElementById('edit-stock-' + id).style.display = 'none';
    document.getElementById('edit-form-' + id).style.display = 'none';
}
</script>
